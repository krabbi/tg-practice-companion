# Copy to .env and fill in real values before running.

# Telegram Bot API token (from @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff-example

# Anthropic API key for AI analysis (AC-11, AC-16)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Groq API key for Whisper voice transcription (optional — leave empty to disable)
GROQ_API_KEY=

# PostgreSQL connection URL
# For Docker Compose, the service name 'db' is the hostname.
DATABASE_URL=postgresql+asyncpg://practice:changeme@db/practice
POSTGRES_USER=practice
POSTGRES_PASSWORD=changeme

# Allowed Telegram user IDs. Comma-separated; a single bare ID is fine too.
# Examples: ALLOWED_USER_IDS=123456789   or   ALLOWED_USER_IDS=123456789,987654321
ALLOWED_USER_IDS=123456789

# Cost guardrails
MONTHLY_COST_LIMIT_USD=10.0
ANALYSIS_COST_CAP_USD=0.05

# AI model pins (override only for testing)
LLM_MODEL=claude-haiku-4-5-20251001
WHISPER_MODEL=whisper-large-v3-turbo

# Bot language
DEFAULT_LANGUAGE=ru

# Send window (local hour, half-open [start, end))
SEND_WINDOW_START=6
SEND_WINDOW_END=22

# Stage 2 — Web API + nginx (docker compose --profile web up -d)
JWT_SECRET=
# Allowed browser origins for the API. Leave EMPTY when the SPA is served from the
# same domain as the API (the default nginx setup) — CORS is then not needed.
# Otherwise comma-separated, e.g. CORS_ORIGINS=https://admin.example.com
CORS_ORIGINS=
WEB_PORT=8000
NGINX_PORT=4100
MEDIA_STORAGE_DIR=/data/media

# Web admin Mini App URL (AC-19) — set to the HTTPS URL of the deployed SPA
# Leave empty to disable the /admin command (the bot will reply "not configured")
WEB_APP_URL=
